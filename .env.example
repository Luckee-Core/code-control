# Optional — leave unset to use same-origin /api/* proxied by next.config.ts (default Express :3010).
# Luckee Hub assigns Express :3074; set CODE_CONTROL_API_URL in .env.local when using the hub.
# NEXT_PUBLIC_CODE_CONTROL_API_URL=http://localhost:3010
CODE_CONTROL_API_URL=http://127.0.0.1:3010
NEXT_PUBLIC_GITHUB_ALLOWED_ORGS=trouthouse-tech,Luckee-Core
NEXT_PUBLIC_GITHUB_DEFAULT_ORG=trouthouse-tech

# Supabase Auth (workspace login)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
